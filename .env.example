# Пример для bin/.env рядом с generate_db_json_local.sh на хосте platform-explorer (db.json),
# не для сервера сайта 161.97.100.254. Скопируйте: cp .env.example .env и отредактируйте.

PLATFORM_EXPLORER_URL=http://127.0.0.1:3005
SAVE_DIR=/home/mno/tmp/withdrawals

# Dash Core / dashmate (подставьте свой вариант)
DASH_CLI=dashmate exec dash_core dash-cli

# Параллельная обработка: rebuild_arrays и обе фазы --incremental-v1 (по умолчанию = число ядер).
# На 1 инкремент на сотнях валидаторов очень медленный; при 429 уменьшите.
# PARALLEL_JOBS=8

# Таймаут секунд для curl в curl_with_retry (GET /validator/… и т.д.; по умолчанию 20).
# CURL_WITH_RETRY_MAX_TIME=30

# Лог $SAVE_DIR/generate_db_json_diag.log:
# 1 — только сбои/ретраи/API (SECTION этапов не пишутся), 0 — плюс границы этапов SECTION
DB_JSON_DIAG_QUIET=1

# Сверка высоты platform-explorer (/status) с dashmate перед генерацией db.json (check_platform_explorer_vs_dashmate.sh).
# SKIP_EXPLORER_DASHMATE_HEIGHT_CHECK=1
# EXPLORER_DASHMATE_DRIFT_MAX=25
# DASHMATE_CONFIG=mainnet

# Опционально: один валидатор, лимит списка, отладка
# VALIDATOR_HASH=
# LIMIT_VALIDATORS=
# DEBUG_VALIDATOR_CREDITS=1
