# Пример для bin/.env рядом с generate_db_json_local.sh на хосте platform-explorer (db.json),
# не для сервера сайта 161.97.100.254. Скопируйте: cp .env.example .env и отредактируйте.

PLATFORM_EXPLORER_URL=http://127.0.0.1:3005
SAVE_DIR=/home/mno/tmp/withdrawals

# Dash Core / dashmate (подставьте свой вариант)
DASH_CLI=dashmate exec dash_core dash-cli

# Параллельная обработка: rebuild_arrays и обе фазы --incremental-v1 (по умолчанию = число ядер nproc).
# platformExp (6 ядер, explorer на localhost): 4 — баланс; 6 — максимум CPU; при 429/API_DIAG в diag — уменьшите до 2–3.
PARALLEL_JOBS=4

# Таймаут секунд для curl в curl_with_retry (GET /validator/… и т.д.; по умолчанию 20).
# CURL_WITH_RETRY_MAX_TIME=30

# Пауза перед каждым GET к platform-explorer в curl_with_retry и в get_validator_blocks (мс). Снижает jq_fail при шторме на :3005.
# Случайная добавка 0..N мс к паузе (разные воркеры не бьют в один такт).
PLATFORM_EXPLORER_REQUEST_GAP_MS=40
PLATFORM_EXPLORER_REQUEST_JITTER_MS=120

# Попыток curl_with_retry (по умолчанию 5; при recover — CURL_WITH_RETRY_RECOVER_ATTEMPTS=6).
# CURL_WITH_RETRY_ATTEMPTS=7

# Режим отладки (пока настраиваете скрипт / explorer API):
# DB_JSON_DEBUG=1 — включает SECTION, CURL_TRACE, API_DIAG (почему сбой), RETRY_FULL на каждую неудачу,
#                   JQ_FIELD при пустом/битом ответе; в cron.log нет сырых «parse error» от jq.
DB_JSON_DEBUG=1

# Тонкая настройка (обычно не нужна при DB_JSON_DEBUG=1):
# CURL_WITH_RETRY_TRACE=1
# DB_JSON_DIAG_QUIET=0

# Лог $SAVE_DIR/generate_db_json_diag.log (если DB_JSON_DEBUG не задан):
# 1 — только сбои/ретраи/API (SECTION этапов не пишутся), 0 — плюс границы этапов SECTION
# DB_JSON_DIAG_QUIET=1
# Все повторные попытки HTTP (attempt>1): grep RETRY_ATTEMPT generate_db_json_diag.log

# generate_db_json_diag.log обнуляется при каждом запуске (как cron.log). Чтобы накапливать между прогонами:
# DB_JSON_KEEP_DIAG=1

# Сверка высоты platform-explorer (/status) с dashmate перед генерацией db.json (check_platform_explorer_vs_dashmate.sh).
# SKIP_EXPLORER_DASHMATE_HEIGHT_CHECK=1
# EXPLORER_DASHMATE_DRIFT_MAX=25

# После догоняния platform-explorer: пересчитать blocks/withdrawals для закрытых эпох (кэш *_through_{curEpoch-1}).
# После догоняния индексера или если blocks есть, а withdrawal=0: один полный прогон, затем убрать.
# DB_JSON_REFRESH_CLOSED_EPOCHS=1
# DASHMATE_CONFIG=mainnet

# IP2Location LITE — скачивание на platformExp и раздача на серверы сайта (см. update_ip2location_db.sh)
# Token: https://www.ip2location.com/file-download
# IP2LOCATION_DOWNLOAD_TOKEN=
# IP2LOCATION_STAGING_DIR=/home/mno/tmp/ip2location
# TARGET_SERVERS="46.19.66.201 161.97.100.254"
# REMOTE_GEO_DB_DIR=/home/mno/bin/db
# REFRESH_GEO_CACHE_AFTER_TRANSFER=1   # после rsync: geolocation_hybrid.py --update-all --force на сайтах

# DB-IP ASN (без token; скачивается вместе с IP2Location, см. update_ip2location_db.sh --only dbip)
# DBIP_DOWNLOAD_BASE=https://download.db-ip.com/free
# DBIP_ASN_LITE_URL=   # опционально: полный URL .gz, иначе авто YYYY-MM

# Опционально: один валидатор, лимит списка, отладка
# VALIDATOR_HASH=
# LIMIT_VALIDATORS=
# DEBUG_VALIDATOR_CREDITS=1

# --- Сервер сайта (201 / 254): patch_db_json_live.sh ---
# PLATFORM_EXPLORER_URL=http://localhost:3005
# DB_JSON=/home/mno/db.json
# SAVE_DIR=/home/mno/tmp/withdrawals
# PLATFORM_EXPLORER_FALLBACK_URL=https://platform-explorer.pshenmic.dev
# DB_JSON_LIVE_LOG=/home/mno/logs/db_json_live.log
# DB_JSON_EPOCH_MISMATCH_LOG=/home/mno/logs/db_json_epoch_mismatch.log

# --- platformExp (96.43): run_db_json_epoch_watch.sh ---
# SKIP_TRANSFER=1
# EPOCH_STATE_FILE=/home/mno/tmp/withdrawals/last_epoch_for_generate.txt
